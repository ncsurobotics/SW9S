{
  // Zenoh config for viewing Jetson ROS topics from your x86 laptop over Tailscale.
  //
  // Usage (on laptop, in any terminal where you want to run ros2 commands):
  //
  //   export RMW_IMPLEMENTATION=rmw_zenoh_cpp
  //   export ZENOH_SESSION_CONFIG_URI=$HOME/zenoh-laptop-client.json5
  //   ros2 topic list
  //   rviz2
  //
  // The Jetson's zenoh router listens on 0.0.0.0:7447 so it's reachable on its
  // Tailscale IP. Update the IP below if your Jetson's Tailscale address changes
  // (run `tailscale ip -4` on the Jetson to confirm).

  mode: "client",

  connect: {
    // Jetson Tailscale IP — update if it changes
    endpoints: ["tcp/100.112.6.65:7447"],
    retry: {
      period_init_ms: 1000,
      period_max_ms: 5000,
      period_increase_factor: 2,
    },
  },

  scouting: {
    // Disable local multicast — we're connecting remotely via Tailscale only
    multicast: { enabled: false },
    gossip:    { enabled: false },
  },

  transport: {
    unicast: {
      qos: { enabled: true },
      compression: { enabled: false },
      lowlatency: false,
    },
    shared_memory: { enabled: false },
  },
}
